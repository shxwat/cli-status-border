{
  "name": "cli-status-border",
  "version": "0.1.0",
  "description": "A reusable animated status border for CLI tools — a colored bar pinned to the top of the terminal that pulses while a task runs, and resolves to a success/error color when it's done. Any color you want, not just green.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "cli-status-border": "./bin/cli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "cli",
    "terminal",
    "tui",
    "progress",
    "spinner",
    "status",
    "border",
    "ansi"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  }
}
